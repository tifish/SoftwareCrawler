true	Android Studio	https://developer.android.com/studio	(async () => {`n    // 通过 XPath 获取单个元素`n    function getByXPath(xpath) {`n        return document.evaluate(`n            xpath, document, null,`n            XPathResult.FIRST_ORDERED_NODE_TYPE, null`n        ).singleNodeValue;`n    }`n`n    // 轮询等待元素满足条件，超时抛错`n    function waitFor(xpath, predicate, timeout = 30000, interval = 200) {`n        return new Promise((resolve, reject) => {`n            const start = Date.now();`n            (function check() {`n                const el = getByXPath(xpath);`n                if (el && (!predicate || predicate(el))) {`n                    resolve(el);`n                    return;`n                }`n                if (Date.now() - start >= timeout) {`n                    reject(new Error('等待超时: ' + xpath));`n                    return;`n                }`n                setTimeout(check, interval);`n            })();`n        });`n    }`n`n    // 1. 找到并点击 “Download Android Studio” 按钮`n    const downloadBtn = await waitFor("//button[contains(text(),'Download Android Studio')]");`n    downloadBtn.click();`n`n    // 2. 等待同意条款的 label 出现并选中`n    const agreeLabel = await waitFor("//label[@id='agreeLabel']");`n    const agreeCheckbox = agreeLabel.querySelector("input[type='checkbox']")`n        || (agreeLabel.htmlFor && document.getElementById(agreeLabel.htmlFor));`n    if (agreeCheckbox && !agreeCheckbox.checked) {`n        agreeCheckbox.click();`n    } else {`n        agreeLabel.click();`n    }`n`n    // 3. 等待 .exe 下载链接变为 enabled 状态并点击`n    const exeLink = await waitFor(`n        "//a[contains(@href, '.exe')]",`n        el => !el.disabled`n            && !el.hasAttribute('disabled')`n            && el.getAttribute('aria-disabled') !== 'true'`n            && !el.classList.contains('disabled')`n    );`n    exeLink.click();`n})();								*.exe			
