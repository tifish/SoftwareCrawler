true	Nvidia 游戏驱动程序	https://www.nvidia.cn/geforce/drivers	async function downloadNvidiaDriver() {`n  const productSeries = "GeForce RTX 40 Series";`n  const downloadId = "driver-popular-download-grd-dnurl";`n`n  function wait(ms) {`n    return new Promise((resolve) => setTimeout(resolve, ms));`n  }`n`n  async function waitFor(predicate, timeoutMs, message) {`n    const start = Date.now();`n    while (Date.now() - start < timeoutMs) {`n      try {`n        if (await predicate()) return;`n      } catch (e) {}`n      await wait(500);`n    }`n    throw new Error("Timeout waiting for " + message);`n  }`n`n  async function waitForElement(selector, timeoutMs) {`n    let $element = null;`n    await waitFor(() => {`n      $element = $(selector);`n      return $element.length > 0;`n    }, timeoutMs, "element " + selector);`n    return $element;`n  }`n`n  async function selectDropdown(id, text) {`n    const $selectElement = await waitForElement("#" + id, 60000);`n`n    // Wait until the desired option exists (options load after parent dropdown changes)`n    await waitFor(() => {`n      return (`n        $selectElement.find("option").filter(function () {`n          return $(this).text().trim() === text;`n        }).length > 0`n      );`n    }, 60000, "option '" + text + "' in #" + id);`n`n    const option = $selectElement.find("option").filter(function () {`n      return $(this).text().trim() === text;`n    });`n`n    $selectElement.val(option.val()).trigger("change");`n    await wait(800);`n  }`n`n  console.log("NVIDIA script: select product series = " + productSeries);`n  await selectDropdown("manualSearch-0", "GeForce");`n  await selectDropdown("manualSearch-1", productSeries);`n`n  // Wait for popular download button with a real navigation target.`n  // Before the page's driver-lookup AJAX completes, href holds the placeholder`n  // "driver-popular-download-*-dnurl" (= the element id), and clicking it 404s.`n  // Only a details-page link ("/drivers/details/<ID>/") or a direct .exe is real.`n  const btnSelector = "#" + downloadId;`n  await waitFor(() => {`n    const el = document.querySelector(btnSelector);`n    if (!el) return false;`n    const href = (el.getAttribute("href") || "").trim();`n    return href.indexOf("/drivers/details") !== -1 || /\.exe(\?|$)/i.test(href);`n  }, 60000, "popular download button " + downloadId);`n`n  console.log("NVIDIA script: click popular download " + downloadId);`n  const btn = document.querySelector(btnSelector);`n  btn.click();`n}`n`n// Return the promise so WebView2 ExecuteScriptAsync waits for completion`ndownloadNvidiaDriver();	(async function downloadNvidiaDetailPage() {`n  function wait(ms) {`n    return new Promise((resolve) => setTimeout(resolve, ms));`n  }`n`n  for (let i = 0; i < 120; i++) {`n    let link =`n      document.getElementById("ddDownloadNow_href") ||`n      document.querySelector('a[href*=".exe"]');`n`n    if (link) {`n      const href = (link.getAttribute("href") || link.href || "").trim();`n      // Only click when the real installer URL is ready (avoids empty href / 404)`n      if (href.includes(".exe") && !href.startsWith("javascript:")) {`n        console.log("NVIDIA script: click detail download " + href);`n        link.click();`n        return true;`n      }`n    }`n    await wait(500);`n  }`n  throw new Error("NVIDIA detail page download link (.exe) not ready");`n})();							*.exe			
